# Optional environment overrides for watchdog/chat.
# Copy to .env and adjust if needed.

OPENCLAW_NODE_BIN=/opt/homebrew/opt/node/bin/node
OPENCLAW_CLI=/Users/huangzhenfeng/openclaw/openclaw.mjs
OPENCLAW_GATEWAY_LABEL=ai.openclaw.gateway
OPENCLAW_GATEWAY_PORT=18789

# Watchdog behavior
OPENCLAW_WATCHDOG_INTERVAL_SECONDS=3
OPENCLAW_HEALTH_CHECK_INTERVAL_SECONDS=30
OPENCLAW_RESTART_WINDOW_SECONDS=60
OPENCLAW_RESTART_MAX_IN_WINDOW=3
OPENCLAW_RESTART_COOLDOWN_SECONDS=300

# Log rotation
OPENCLAW_LOG_ROTATE_MAX_BYTES=52428800
OPENCLAW_LOG_ROTATE_KEEP=5

# Chat helper timeout
OPENCLAW_CHAT_TIMEOUT_SECONDS=60
OPENCLAW_AGENT_ID=main

# Post-boot verification
OPENCLAW_POSTBOOT_TIMEOUT_SECONDS=90
OPENCLAW_POSTBOOT_INTERVAL_SECONDS=3

# Backups
OPENCLAW_BACKUP_DIR=/Users/huangzhenfeng/WorkSpace/openclaw-watchdog/backups

# Alerts (optional)
# Generic webhook:
# OPENCLAW_ALERT_WEBHOOK_URL=https://your-webhook.example.com/path
#
# Telegram:
# OPENCLAW_ALERT_TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
# OPENCLAW_ALERT_TELEGRAM_CHAT_ID=6402657757
#
# Alert behavior:
OPENCLAW_ALERT_TIMEOUT_SECONDS=8
OPENCLAW_ALERT_DEDUP_WINDOW_SECONDS=120
