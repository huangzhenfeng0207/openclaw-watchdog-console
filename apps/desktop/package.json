{
  "name": "openclaw-desktop",
  "version": "0.1.0",
  "description": "Attach-only macOS desktop guardian for local OpenClaw runtimes",
  "author": "OpenClaw Team",
  "private": true,
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "electron .",
    "build:dmg": "electron-builder --mac dmg --arm64"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.openclaw.desktop",
    "productName": "OpenClaw Guardian",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "files": [
      "main.mjs",
      "preload.cjs",
      "ui/**/*"
    ],
    "extraResources": [
      {
        "from": "../../adapter",
        "to": "app-root/adapter"
      },
      {
        "from": "../../shared",
        "to": "app-root/shared"
      },
      {
        "from": "../../supervisor",
        "to": "app-root/supervisor"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
